{
  "name": "semantic-search-ext",
  "displayName": "Semantic Search Ext",
  "description": "Semantic code search for VS Code with an auto-installed local runtime",
  "version": "0.0.1",
  "publisher": "nk-labs314",
  "license": "SEE LICENSE IN LICENSE.txt",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "semantic-search",
    "code-search",
    "python",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nk-labs314/Semantic-Search-Extension"
  },
  "bugs": {
    "url": "https://github.com/nk-labs314/Semantic-Search-Extension/issues"
  },
  "homepage": "https://github.com/nk-labs314/Semantic-Search-Extension",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:semanticSearch.search"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "npx @vscode/vsce package",
    "package:pre-release": "npx @vscode/vsce package --pre-release",
    "runtime:bundle": "backend/.venv-release/Scripts/python.exe scripts/build_windows_standalone_runtime.py --venv backend/.venv-release"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "semanticSearch.search",
        "title": "Semantic Code Search"
      },
      {
        "command": "semanticSearch.installRuntime",
        "title": "Semantic Search: Install Runtime"
      },
      {
        "command": "semanticSearch.reinstallRuntime",
        "title": "Semantic Search: Reinstall Runtime"
      },
      {
        "command": "semanticSearch.showBackendLogs",
        "title": "Semantic Search: Show Backend Logs"
      }
    ],
    "keybindings": [
      {
        "command": "semanticSearch.search",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "configuration": {
      "title": "Semantic Search Ext",
      "properties": {
        "semanticSearch.runtimeBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL that hosts runtime archives named like semantic-search-runtime-win32-x64.zip. If empty, the extension derives a GitHub Releases URL from package.json.repository."
        },
        "semanticSearch.runtimeVersion": {
          "type": "string",
          "default": "",
          "description": "Runtime version tag to download. Leave empty to use the extension version."
        },
        "semanticSearch.autoInstallRuntime": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download the runtime on first activation when it is missing."
        },
        "semanticSearch.autoIndexOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the backend and index the active workspace on startup."
        }
      }
    }
  }
}
